<Window x:Class="PuntoDeVentaFarmacia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PuntoDeVentaFarmacia.Converters"
        Title="Farmacia Vital · Punto de Venta"
        Width="1440" Height="840" MinWidth="1180" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource FondoVentanaBrush}"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:CategoriaIconoConverter x:Key="CategoriaIcono"/>
        <conv:StockColorConverter x:Key="StockColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:MayorQueCeroConverter x:Key="MayorQueCero"/>
        <conv:BooleanoInversoConverter x:Key="BoolInverso"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ BARRA DE TÍTULO PERSONALIZADA ============ -->
        <Border Grid.Row="0" Background="{StaticResource FondoPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <TextBlock Text="🏥" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Farmacia Vital" Foreground="{StaticResource TextoPrimarioBrush}" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="  ·  Punto de Venta" Foreground="{StaticResource TextoSecundarioBrush}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimizar" Content="&#xE921;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BotonIcono}" Click="BtnMinimizar_Click" Margin="0,0,4,0"/>
                    <Button x:Name="BtnMaximizar" Content="&#xE922;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BotonIcono}" Click="BtnMaximizar_Click" Margin="0,0,4,0"/>
                    <Button x:Name="BtnCerrar" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Style="{StaticResource BotonIcono}" Click="BtnCerrar_Click" Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ CUERPO PRINCIPAL ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ============ SIDEBAR ============ -->
            <Border Grid.Column="0" Background="{StaticResource FondoPanelBrush}">
                <DockPanel Margin="18,20,18,20">
                    <StackPanel DockPanel.Dock="Top">
                        <!-- Buscador -->
                        <Grid Margin="0,0,0,18">
                            <TextBox x:Name="TxtBuscar" Style="{StaticResource CampoTexto}" TextChanged="TxtBuscar_TextChanged"/>
                            <TextBlock x:Name="TxtPlaceholderBuscar" Text="🔍  Buscar producto..." Foreground="{StaticResource TextoSecundarioBrush}"
                                       Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="13"/>
                        </Grid>

                        <TextBlock Text="CATEGORÍAS" Style="{StaticResource TextoMuted}" Margin="6,0,0,10" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Border Background="{StaticResource FondoTarjetaBrush}" CornerRadius="12" Padding="14" Margin="0,14,0,14">
                            <StackPanel>
                                <TextBlock Text="VENTAS DE HOY" Style="{StaticResource TextoMuted}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🧾" FontSize="18" Margin="0,0,8,0"/>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtVentasHoyTotal" Text="RD$ 0.00" Foreground="{StaticResource AcentoPrimarioBrush}" FontWeight="Bold" FontSize="17"/>
                                        <TextBlock x:Name="TxtVentasHoyCantidad" Text="0 transacciones" Style="{StaticResource TextoMuted}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Button Content="⚙️  Gestionar productos" Style="{StaticResource BotonSecundario}" HorizontalAlignment="Stretch" Click="BtnGestionarProductos_Click"/>
                    </StackPanel>

                    <ListBox x:Name="ListaCategorias" Style="{StaticResource ListaCategorias}" ItemContainerStyle="{StaticResource ItemCategoria}"
                             SelectionChanged="ListaCategorias_SelectionChanged" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Converter={StaticResource CategoriaIcono}}" FontSize="15" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ============ CATÁLOGO DE PRODUCTOS ============ -->
            <Grid Grid.Column="1" Margin="26,22,20,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock x:Name="TxtTituloCategoria" Text="Todos los productos" Style="{StaticResource Titulo1}"/>
                    <TextBlock x:Name="TxtCantidadProductos" Text="0 productos disponibles" Style="{StaticResource TextoMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListaProductos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FondoTarjetaBrush}" CornerRadius="14" Width="228" Height="220" Margin="0,0,16,16" Padding="16">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="1.4"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AcentoPrimarioBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource FondoPanelBrush}" CornerRadius="10" Width="42" Height="42">
                                                <TextBlock Text="{Binding Categoria, Converter={StaticResource CategoriaIcono}}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" Background="{StaticResource AcentoPeligroBrush}" CornerRadius="8" Padding="7,3" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Visibility="{Binding RequiereReceta, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="RECETA" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                            <TextBlock Text="{Binding Nombre}" Foreground="{StaticResource TextoPrimarioBrush}" FontWeight="SemiBold" FontSize="13.5"
                                                       TextWrapping="Wrap" MaxHeight="40"/>
                                            <TextBlock Text="{Binding Laboratorio}" Style="{StaticResource TextoMuted}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,10">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Stock, Converter={StaticResource StockColor}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Stock, StringFormat={}{0} en existencia}" Style="{StaticResource TextoMuted}"/>
                                        </StackPanel>

                                        <Grid Grid.Row="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding PrecioFormateado}" Foreground="{StaticResource AcentoPrimarioBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="&#xE710;" FontFamily="Segoe MDL2 Assets" Width="36" Height="36" Style="{StaticResource BotonPrimario}"
                                                    Padding="0" Click="BtnAgregarAlCarrito_Click" Tag="{Binding}" IsEnabled="{Binding SinStock, Converter={StaticResource BoolInverso}}"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ============ CARRITO ============ -->
            <Border Grid.Column="2" Background="{StaticResource FondoPanelBrush}">
                <Grid Margin="22,22,22,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🛒" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="Carrito" Style="{StaticResource Titulo2}"/>
                        <Border Background="{StaticResource AcentoPrimarioBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                Visibility="{Binding ElementName=ListaCarrito, Path=Items.Count, Converter={StaticResource MayorQueCero}}">
                            <TextBlock x:Name="TxtCantidadCarrito" Text="0" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextoSobreAcentoBrush}"/>
                        </Border>
                        <Button Content="Vaciar" Style="{StaticResource BotonIcono}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource AcentoPeligroBrush}"
                                HorizontalAlignment="Right" Click="BtnVaciarCarrito_Click" Width="NaN" Padding="6,4" Margin="60,0,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <TextBlock x:Name="TxtCarritoVacio" Text="Tu carrito está vacío.&#10;Agrega productos desde el catálogo." Style="{StaticResource TextoMuted}"
                                   TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ListaCarrito">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource FondoTarjetaBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Nombre}" Foreground="{StaticResource TextoPrimarioBrush}"
                                                           FontWeight="SemiBold" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                                <Button Grid.Row="0" Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                        Style="{StaticResource BotonIcono}" Width="22" Height="22" Foreground="{StaticResource TextoSecundarioBrush}"
                                                        Click="BtnQuitarDelCarrito_Click" Tag="{Binding}"/>

                                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="−" Width="26" Height="26" Style="{StaticResource BotonSecundario}" Padding="0" FontSize="14"
                                                                Click="BtnRestarCantidad_Click" Tag="{Binding}"/>
                                                        <TextBlock Text="{Binding Cantidad}" Width="30" TextAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{StaticResource TextoPrimarioBrush}" FontWeight="SemiBold"/>
                                                        <Button Content="+" Width="26" Height="26" Style="{StaticResource BotonSecundario}" Padding="0" FontSize="14"
                                                                Click="BtnSumarCantidad_Click" Tag="{Binding}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding SubtotalFormateado}" Foreground="{StaticResource AcentoPrimarioBrush}"
                                                               FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <Border Height="1" Background="{StaticResource BordeBrush}" Margin="0,0,0,14"/>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Subtotal" Style="{StaticResource TextoMuted}"/>
                            <TextBlock x:Name="TxtSubtotal" Text="RD$ 0.00" Foreground="{StaticResource TextoPrimarioBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="ITBIS (18%)" Style="{StaticResource TextoMuted}"/>
                            <TextBlock x:Name="TxtImpuesto" Text="RD$ 0.00" Foreground="{StaticResource TextoPrimarioBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,18">
                            <TextBlock Text="Total" Style="{StaticResource Titulo2}"/>
                            <TextBlock x:Name="TxtTotal" Text="RD$ 0.00" Foreground="{StaticResource AcentoPrimarioBrush}" FontWeight="Bold" FontSize="22" HorizontalAlignment="Right"/>
                        </Grid>
                        <Button x:Name="BtnCobrar" Content="Cobrar" Style="{StaticResource BotonPrimario}" HorizontalAlignment="Stretch" FontSize="15" Click="BtnCobrar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
