using System;

class Program
{
    static void Main()
    {
        Console.Write("Ingrese el primer número: ");
        double num1 = Convert.ToDouble(Console.ReadLine());

        Console.Write("Ingrese el segundo número: ");
        double num2 = Convert.ToDouble(Console.ReadLine());

        // Operaciones básicas
        Console.WriteLine("\nResultados:");
        Console.WriteLine("Suma: " + (num1 + num2));
        Console.WriteLine("Resta: " + (num1 - num2));
        Console.WriteLine("Multiplicación: " + (num1 * num2));

        // División
        if (num2 != 0)
        {
            Console.WriteLine("División: " + (num1 / num2));
        }
        else
        {
            Console.WriteLine("División: No se puede dividir entre cero.");
        }

        // Raíces cuadradas
        if (num1 >= 0)
        {
            Console.WriteLine("Raíz cuadrada del primer número: " + Math.Sqrt(num1));
        }
        else
        {
            Console.WriteLine("El primer número no tiene raíz cuadrada real.");
        }

        if (num2 >= 0)
        {
            Console.WriteLine("Raíz cuadrada del segundo número: " + Math.Sqrt(num2));
        }
        else
        {
            Console.WriteLine("El segundo número no tiene raíz cuadrada real.");
        }
    }
}
